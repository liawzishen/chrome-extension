# Choose one provider and add only that provider's server-side key.
AI_PROVIDER=gemini
GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite

# Alternative OpenAI configuration:
# AI_PROVIDER=openai
# OPENAI_API_KEY=replace-with-your-openai-api-key
# OPENAI_MODEL=your-supported-model
# OPENAI_REASONING_EFFORT=low

# Copy the exact ID from chrome://extensions after loading the unpacked build.
ALLOWED_EXTENSION_ORIGINS=chrome-extension://your-32-character-extension-id
ALLOWED_PREVIEW_ORIGINS=http://127.0.0.1:8788,http://localhost:8788

# The backend binds to 127.0.0.1. Leave BACKEND_ACCESS_TOKEN blank to generate
# a private token in .exam-cram-backend-token for non-extension clients.
PORT=8787
BACKEND_ACCESS_TOKEN=

# Resource and cost controls. Keep these bounded unless you understand the impact.
AI_REQUEST_TIMEOUT_MS=45000
MAX_CONCURRENT_API_REQUESTS=2
MAX_API_REQUESTS_PER_MINUTE=60
MAX_REQUEST_BODY_BYTES=3145728
MAX_STUDY_CHARS=22000
MAX_NOTES_CHARS=24000
MAX_COLLECTION_CHARS=60000
