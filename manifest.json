{
  "manifest_version": 3,
  "name": "NeatMind",
  "version": "0.7.0",
  "minimum_chrome_version": "116",
  "description": "Study pages and videos with source-grounded visual lessons, active recall, focus controls, and a dated learning journey.",
  "action": {
    "default_title": "Open NeatMind"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      }
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'none'"
  },
  "permissions": [
    "activeTab",
    "alarms",
    "declarativeNetRequestWithHostAccess",
    "offscreen",
    "sidePanel",
    "scripting",
    "storage",
    "tabCapture"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "optional_host_permissions": [
    "*://*/*",
    "file:///*"
  ]
}
